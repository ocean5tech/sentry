#!/usr/bin/env bash
# q-seed-short: 三红买入策略 — 实时扫描当日在买入点/起爆日的股票
# 结果合并为一条消息推送，不做 LLM 分析
#
# 用法:
#   q-seed-short           # 扫描全市场, 推送汇总消息
#   q-seed-short --dry     # 不推送，只打印
set -euo pipefail

SELF="$(readlink -f "$0")"
ROOT="$(dirname "$SELF")/.."
LOG="$ROOT/logs/q-seed-short.log"
mkdir -p "$ROOT/logs"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG"; }

DRY=0
for arg in "$@"; do
    case "$arg" in
        --dry) DRY=1 ;;
    esac
done

log "=== q-seed-short 启动 ==="

# 1. 交易日检查
if ! "$ROOT/scripts/is_trading_day"; then
    log "今天非交易日, 退出"
    exit 0
fi
log "今天是交易日, 继续"

# 2. 加载 .env
[ -f "$ROOT/.env" ] && { set -a; source "$ROOT/.env"; set +a; }

PYTHON="$ROOT/.venv/bin/python"

# 3. 扫描
log "扫描 three_red_bars_v4 策略..."
TMP_SCAN=$(mktemp /tmp/short_scan_XXXXXX.json)

"$PYTHON" "$ROOT/scripts/run_scan.py" \
    --strategy three_red_bars_v4 \
    --min-score 4 \
    --quiet \
    --format json \
    --output "$TMP_SCAN" \
    2>>"$LOG" || true

if [ ! -s "$TMP_SCAN" ]; then
    log "今日无三红买入/起爆信号，退出"
    rm -f "$TMP_SCAN"
    exit 0
fi

HIT_COUNT=$("$PYTHON" -c "import json; d=json.load(open('$TMP_SCAN')); print(len(d))")
log "命中 $HIT_COUNT 只"

if [ "$DRY" -eq 1 ]; then
    "$PYTHON" - <<PYEOF
import json, sys
sys.path.insert(0, '$ROOT/q-push')
from main import format_three_red_batch
from datetime import date
hits = json.load(open('$TMP_SCAN'))
print(format_three_red_batch(hits, date.today().strftime('%Y-%m-%d')))
PYEOF
    rm -f "$TMP_SCAN"
    log "DRY-RUN 完成"
    exit 0
fi

# 4. 格式化并推送（单条消息）
log "推送汇总消息..."
"$PYTHON" - <<PYEOF 2>>"$LOG"
import json, os, sys
sys.path.insert(0, '$ROOT/q-push')
sys.path.insert(0, '$ROOT')

# 加载 .env
from pathlib import Path
env = Path('$ROOT/.env')
if env.exists():
    for ln in env.read_text().splitlines():
        ln = ln.strip()
        if ln and not ln.startswith('#') and '=' in ln:
            k, _, v = ln.partition('=')
            os.environ.setdefault(k.strip(), v.strip())

from main import format_three_red_batch, post_webhook
from datetime import date

hits = json.load(open('$TMP_SCAN'))
msg = format_three_red_batch(hits, date.today().strftime('%Y-%m-%d'))

webhook = os.environ.get('WECHAT_WEBHOOK_URL', '')
if not webhook:
    print('[q-seed-short] ERROR: WECHAT_WEBHOOK_URL 未设', file=sys.stderr)
    sys.exit(1)

result = post_webhook(webhook, msg, 'markdown')
if result.get('ok'):
    print('[q-seed-short] ✅ 推送成功', file=sys.stderr)
else:
    print(f'[q-seed-short] ❌ 推送失败: {result}', file=sys.stderr)
    sys.exit(1)
PYEOF

rm -f "$TMP_SCAN"
log "=== q-seed-short 结束 ==="
