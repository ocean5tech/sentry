#!/usr/bin/env bash
# q-hongjing-batch: 已并入 q-pick-today，此脚本为向后兼容保留
# 宏景三角旗扫描现在是 q-pick-today 的内置步骤 (config: hongjing_pennant.enabled)
# 直接调用 q-pick-today，跳过数据同步
set -euo pipefail

SELF="$(readlink -f "$0")"
ROOT="$(dirname "$SELF")/.."

DRY_FLAG=""
for arg in "$@"; do
    case "$arg" in --dry) DRY_FLAG="--skip-push" ;; esac
done

exec "$ROOT/scripts/q-pick-today" --skip-sync $DRY_FLAG
