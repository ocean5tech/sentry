#!/usr/bin/env bash
# 疯牛种子 - 宏景型 (短期波浪 + 严格 HH/Pierce)
# 用法:
#   q-seed-hongjing              # 默认 TOP 20 基本面
#   q-seed-hongjing 50           # TOP 50
#   q-seed-hongjing --skip-scan  # 跳过扫描, 用上次的 CSV 拉基本面
set -e
cd "$(dirname "$0")/.."
source .venv/bin/activate

TOP=20
SKIP=0
for arg in "$@"; do
    case "$arg" in
        --skip-scan) SKIP=1 ;;
        [0-9]*) TOP="$arg" ;;
    esac
done

if [[ $SKIP -eq 0 ]]; then
    echo "===== 疯牛种子-宏景 Step 1/2: 全市场扫描 (~12 分钟) ====="
    python3 -u scripts/find_similar_to_template.py --template hongjing
    echo ""
fi

echo "===== 疯牛种子-宏景 Step 2/2: TOP $TOP 基本面 ====="
python3 -u scripts/fetch_candidate_fundamentals.py --from-csv logs/similar_to_hongjing.csv --top "$TOP"

echo ""
echo "===== 完成 ====="
echo "  形态: logs/similar_to_hongjing.csv"
echo "  基本面: logs/fundamentals_hongjing.csv"
