# sentry/quant 密钥模板
# 私有仓库可直接使用 .env，公开仓库请勿提交真实密钥

# LLM API（二选一，推荐 DeepSeek，约 4x 便宜）
ANTHROPIC_API_KEY=sk-ant-api03-...
DEEPSEEK_API_KEY=sk-...

# 企业微信 webhook（群机器人 → 配置 → Webhook 地址）
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...

# 搜索备用（DDG 失败时自动切换，免费 1000次/月）
TAVILY_API_KEY=tvly-...
